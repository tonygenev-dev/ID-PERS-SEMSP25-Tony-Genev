@startuml
' Define SimpleDate
class SimpleDate {
    - int day
    - int month
    - int year
    + SimpleDate(int, int, int)
    + int GetDay()
    + int GetMonth()
    + int GetYear()
    + int DaysDifference(SimpleDate)
    + std::string ToString()
}

' Sedan
class Sedan {
    - std::string manufacturer
    - std::string model
    - int licencePlate
    - int kilometers
    - bool hasTowbar
    - SimpleDate* rentalDate
    + Sedan(std::string, std::string, int, bool)
    + std::string GetManufacturer()
    + std::string GetModel()
    + int GetLicencePlate()
    + int GetKilometers()
    + bool IsAvailable()
    + bool HasTowbarFunc()
    + bool Rent(SimpleDate)
    + double Return(SimpleDate, int)
    + std::string ToString()
}

' Limousine
class Limousine {
    - std::string manufacturer
