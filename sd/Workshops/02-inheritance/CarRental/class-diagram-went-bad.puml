' Truck
class Truck {
    - std::string manufacturer
    - std::string model
    - int licencePlate
    - int kilometers
    - int cargoSpace
    - int maxWeight
    - SimpleDate* rentalDate
    + Truck(std::string, std::string, int, int, int)
    + std::string GetManufacturer()
    + std::string GetModel()
    + int GetLicencePlate()
    + int GetKilometers()
    + int GetCargoSpace()
    + int GetMaxWeight()
    + bool IsAvailable()
    + bool Rent(SimpleDate)
    + double Return(SimpleDate, int)
    + std::string ToString()
}

' RentalAdministration
class RentalAdministration {
    - std::vector<Sedan*> sedans
    - std::vector<Limousine*> limousines
    - std::vector<Truck*> trucks
    + RentalAdministration()
    + std::vector<Sedan*> GetSedans()
    + std::vector<Limousine*> GetLimousines()
    + std::vector<Truck*> GetTrucks()
    + void Add(Sedan*)
    + void Add(Limousine*)
    + void Add(Truck*)
    + bool RentCar(int, SimpleDate)
    + double ReturnCar(int, SimpleDate, int)
}

' Relationships
Sedan --> SimpleDate : rentalDate
Limousine --> SimpleDate : rentalDate
Truck --> SimpleDate : rentalDate

RentalAdministration "1" o-- "*" Sedan
RentalAdministration "1" o-- "*" Limousine
RentalAdministration "1" o-- "*" Truck
